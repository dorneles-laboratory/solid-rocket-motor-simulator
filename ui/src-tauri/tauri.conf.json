{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SRM",
  "version": "0.2.0",
  "identifier": "com.srm",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Solid Rocket Motor",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/rocket.ico"],
    "externalBin": ["bin/engine"]
  }
}
